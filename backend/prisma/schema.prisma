generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskDraft {
  id              String   @id @default(cuid())
  title           String
  category        String
  difficulties    String
  bodyBlocks      String
  challengeBlocks String
  answerType      String   @default("multiple_choice")
  multipleChoiceOrderMode String @default("fixed")
  answers         String
  correctAnswerId String
  shortAnswer     String   @default("")
  rangeAnswers    String   @default("[]")
  dragDropBackground String @default("null")
  dragDropItems   String   @default("[]")
  explanation     String
  status          String   @default("Borrador")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  contestTasks    ContestTask[]
  attemptAnswers  AttemptAnswer[]
}

model Contest {
  id               String         @id @default(cuid())
  title            String
  level            String
  year             Int            @default(2026)
  durationMinutes  Int
  startsAt         DateTime
  endsAt           DateTime
  isOpen           Boolean        @default(false)
  allowPairs       Boolean        @default(false)
  showFeedback     Boolean        @default(false)
  showSolutions    Boolean        @default(false)
  showTotalScore   Boolean        @default(false)
  isVisible        Boolean        @default(false)
  status           String         @default("draft")
  folderSecret     String         @default("")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tasks            ContestTask[]
  groups           ContestGroup[]
}

model ContestTask {
  id           String    @id @default(cuid())
  contestId    String
  taskDraftId  String
  position     Int
  minScore     Int       @default(0)
  noAnswerScore Int      @default(0)
  maxScore     Int       @default(10)
  options      String    @default("{}")
  createdAt    DateTime  @default(now())
  contest      Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  taskDraft    TaskDraft @relation(fields: [taskDraftId], references: [id], onDelete: Restrict)

  @@unique([contestId, taskDraftId])
  @@unique([contestId, position])
  @@index([contestId, position])
}

model ContestGroup {
  id            String    @id @default(cuid())
  contestId     String
  name          String
  accessCode    String    @unique
  recoveryCode  String
  firstUsedAt   DateTime?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  contest       Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  teams         Team[]

  @@index([contestId])
}

model Team {
  id                 String        @id @default(cuid())
  groupId            String
  participationMode  String        @default("individual")
  memberOneName      String
  memberTwoName      String?
  personalCode       String        @unique
  status             String        @default("registered")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  group              ContestGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attempt            Attempt?

  @@index([groupId])
}

model Attempt {
  id            String          @id @default(cuid())
  teamId        String          @unique
  startedAt     DateTime?
  endsAt        DateTime?
  finishedAt    DateTime?
  status        String          @default("pending")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  team          Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  answers       AttemptAnswer[]
  result        Result?
}

model AttemptAnswer {
  id             String     @id @default(cuid())
  attemptId      String
  taskDraftId    String
  responsePayload String
  isCorrect      Boolean?
  score          Int        @default(0)
  answeredAt     DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  attempt        Attempt    @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  taskDraft      TaskDraft  @relation(fields: [taskDraftId], references: [id], onDelete: Restrict)

  @@unique([attemptId, taskDraftId])
  @@index([attemptId])
}

model Result {
  id            String    @id @default(cuid())
  attemptId     String    @unique
  totalScore    Int       @default(0)
  correctCount  Int       @default(0)
  answeredCount Int       @default(0)
  rankPosition  Int?
  calculatedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  attempt       Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
}
