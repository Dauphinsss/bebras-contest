{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.5",
  "description": "API con Express y TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch ./src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "dotenv": "^17.3.1",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  }
}
