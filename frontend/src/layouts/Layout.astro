---
import "../styles/global.css";
import { AppToaster } from "../components/app-toaster";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title?: string;
  heading?: string;
  backHref?: string;
  requireAuth?: boolean;
}

const {
  title = "Bebras",
  heading,
  backHref,
  requireAuth = false,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {
      requireAuth && (
        <script is:inline>
          if (!localStorage.getItem("bebras_token")) {
            window.location.replace("/login");
          }
        </script>
      )
    }
  </head>
  <body>
    <div class="flex min-h-screen flex-col">
      <SiteHeader heading={heading} backHref={backHref} />
      <div class="flex-1">
        <slot />
      </div>
      <SiteFooter />
    </div>
    <AppToaster client:load />
  </body>
</html>
