---
import "../styles/global.css";
import { AppToaster } from "../components/app-toaster";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title?: string;
  heading?: string;
  backHref?: string;
  requireAuth?: boolean;
  allowMaestro?: boolean;
}

const {
  title = "Bebras",
  heading,
  backHref,
  requireAuth = false,
  allowMaestro = false,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/castor.png" />
    <title>{title}</title>
    {
      requireAuth && (
        <script is:inline define:vars={{ allowMaestro }}>
          (function () {
            var raw = localStorage.getItem("bebras_user");
            var user = raw ? JSON.parse(raw) : null;
            if (!localStorage.getItem("bebras_token") || !user) {
              window.location.replace("/login");
              return;
            }
            var ok =
              user.role === "admin" ||
              (allowMaestro && user.role === "maestro");
            if (!ok) {
              window.location.replace("/");
            }
          })();
        </script>
      )
    }
  </head>
  <body>
    <div class="flex min-h-screen flex-col">
      <SiteHeader heading={heading} backHref={backHref} />
      <div class="flex-1">
        <slot />
      </div>
      <SiteFooter />
    </div>
    <AppToaster client:load />
  </body>
</html>
