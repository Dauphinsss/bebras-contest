---
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { ContestFormPage } from "../../components/contest-form-page";

const title = "Editar competencia";
---

<Layout title={title} heading="Editar competencia" backHref="/competencias" requireAuth>
  <main class="mx-auto flex w-full max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex w-full flex-col gap-6">
      <header class="flex flex-col gap-4">
        <Breadcrumb
          items={[
            { label: "Competencias", href: "/competencias" },
            { label: "Editar" },
          ]}
        />
        <p class="max-w-3xl text-sm leading-6 text-muted-foreground sm:text-base">
          Ajusta fechas, reglas y orden de tareas de una competencia ya creada.
        </p>
      </header>

      <ContestFormPage client:only="react" />
    </div>
  </main>
</Layout>
