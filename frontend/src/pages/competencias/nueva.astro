---
import Layout from "../../layouts/Layout.astro";
import { ContestFormPage } from "../../components/contest-form-page";

const title = "Nueva competencia";
---

<Layout title={title}>
  <main class="mx-auto flex min-h-screen w-full max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex w-full flex-col gap-6">
      <header class="flex flex-col gap-4">
        <a href="/competencias" class="text-sm text-muted-foreground transition hover:text-foreground">
          Volver a competencias
        </a>
        <div class="flex flex-col gap-2">
          <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">
            Crear competencia
          </h1>
          <p class="max-w-3xl text-sm leading-6 text-muted-foreground sm:text-base">
            Define la competencia y ordena el conjunto de tareas que la compondrán.
          </p>
        </div>
      </header>

      <ContestFormPage client:only="react" />
    </div>
  </main>
</Layout>
