---
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { TaskEditPage } from "../../components/task-edit-page";

const title = "Editar tarea";
---

<Layout title={title} heading="Editar tarea" backHref="/tareas" requireAuth>
  <main class="mx-auto flex w-full max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex w-full flex-col gap-6">
      <header class="flex flex-col gap-4">
        <Breadcrumb
          items={[{ label: "Tareas", href: "/tareas" }, { label: "Editar" }]}
        />
      </header>

      <TaskEditPage client:only="react" />
    </div>
  </main>
</Layout>
