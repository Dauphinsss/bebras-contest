---
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { TaskUploadForm } from "../../components/task-upload-form";

const title = "Registrar tarea";
---

<Layout title={title} heading="Registrar tarea" backHref="/tareas" requireAuth>
  <main class="mx-auto flex w-full max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex w-full flex-col gap-6">
      <header class="flex flex-col gap-4">
        <Breadcrumb
          items={[{ label: "Tareas", href: "/tareas" }, { label: "Registrar" }]}
        />
      </header>

      <TaskUploadForm client:load />
    </div>
  </main>
</Layout>
