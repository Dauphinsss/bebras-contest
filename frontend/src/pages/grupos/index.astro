---
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { GroupsHome } from "../../components/groups-home";

const title = "Grupos";
---

<Layout title={title} requireAuth>
  <main class="mx-auto flex w-full max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex w-full flex-col gap-6">
      <Breadcrumb items={[{ label: "Grupos" }]} />
      <GroupsHome client:load />
    </div>
  </main>
</Layout>
